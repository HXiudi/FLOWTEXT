{
  "name": "flowtext",
  "version": "1.1.0",
  "description": "A Typora-like Markdown editor with visual formatting toolbar, Apple-style design",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable --x64",
    "release": "npm run build"
  },
  "author": "FLOWTEXT",
  "license": "MIT",
  "build": {
    "appId": "com.flowtext.app",
    "productName": "FLOWTEXT",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "icon": "src/assets/icon.png",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "FLOWTEXT-v${version}-portable.exe",
      "requestExecutionLevel": "user"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "marked": "^18.0.4",
    "turndown": "^7.2.4"
  }
}
